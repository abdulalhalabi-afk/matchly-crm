{
  "name": "matchly-crm-backend",
  "version": "1.0.0",
  "description": "Backend für Matchly CRM - Lokale Service-App",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "ts-node src/database/init.ts",
    "db:seed": "ts-node src/database/seed.ts",
    "test": "jest",
    "postinstall": "npm rebuild sqlite3"
  },
  "keywords": [
    "crm",
    "service",
    "contact-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^29.5.2",
    "@types/sequelize": "^4.28.20",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^9.0.2",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  }
